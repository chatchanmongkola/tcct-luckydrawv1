// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ===== User =====
model User {
  id        String    @id @default(uuid()) @db.Uuid
  email     String    @unique
  username  String    @unique
  password  String
  name      String?
  role      String    @default("USER")
  expiresAt DateTime? @map("expires_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Campaign {
  id           String         @id @default(uuid()) @db.Uuid
  title        String
  slug         String         @unique
  description  String?
  bannerUrl    String?        @map("banner_url")
  status       CampaignStatus @default(DRAFT)
  startsAt     DateTime?      @map("starts_at")
  endsAt       DateTime?      @map("ends_at")
  isDeleted    Boolean        @default(false) @map("is_deleted")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  participants Participant[]
  prizeTiers   PrizeTier[]
  drawSessions DrawSession[]
  drawResults  DrawResult[]

  @@map("campaigns")
}

model Participant {
  id          String       @id @default(uuid()) @db.Uuid
  campaignId  String       @map("campaign_id") @db.Uuid
  employeeId  String       @map("employee_id")
  name        String
  mobile      String
  isDeleted   Boolean      @default(false) @map("is_deleted")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  campaign    Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  drawResults DrawResult[]

  @@index([campaignId])
  @@map("participants")
}

model PrizeTier {
  id           String        @id @default(uuid()) @db.Uuid
  campaignId   String        @map("campaign_id") @db.Uuid
  tierName     String        @map("tier_name")
  description  String?
  quantity     Int
  sortOrder    Int           @default(1) @map("sort_order")
  isDeleted    Boolean       @default(false) @map("is_deleted")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  campaign     Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  drawSessions DrawSession[]
  drawResults  DrawResult[]

  @@index([campaignId])
  @@map("prize_tiers")
}

model DrawSession {
  id          String       @id @default(uuid()) @db.Uuid
  campaignId  String       @map("campaign_id") @db.Uuid
  prizeTierId String       @map("prize_tier_id") @db.Uuid
  state       DrawState    @default(COMPLETED)
  nonce       String
  drawnAt     DateTime     @default(now()) @map("drawn_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  campaign    Campaign     @relation(fields: [campaignId], references: [id])
  prizeTier   PrizeTier    @relation(fields: [prizeTierId], references: [id])
  results     DrawResult[]

  @@index([campaignId])
  @@index([prizeTierId])
  @@map("draw_sessions")
}

model DrawResult {
  id            String      @id @default(uuid()) @db.Uuid
  campaignId    String      @map("campaign_id") @db.Uuid
  drawSessionId String      @map("draw_session_id") @db.Uuid
  participantId String      @map("participant_id") @db.Uuid
  prizeTierId   String      @map("prize_tier_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at")
  campaign      Campaign    @relation(fields: [campaignId], references: [id])
  drawSession   DrawSession @relation(fields: [drawSessionId], references: [id])
  participant   Participant @relation(fields: [participantId], references: [id])
  prizeTier     PrizeTier   @relation(fields: [prizeTierId], references: [id])

  @@unique([campaignId, participantId])
  @@index([campaignId])
  @@index([drawSessionId])
  @@map("draw_results")
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum DrawState {
  READY
  DRAWING
  COMPLETED
}
